APP_BASE_URL=https://angebote.daltec.at
ADMIN_PORT=3030
NODE_ENV=production

ADMIN_EMAIL=admin@daltec.local
# Fuer Production bevorzugt ADMIN_PASSWORD_HASH statt ADMIN_PASSWORD nutzen.
# Generate:
# node -e "import('./src/auth.js').then(m=>console.log(m.createPasswordHash('CHANGE_ME_LONG_RANDOM_PASSWORD')))"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_TENANT_ID=daltec-local
EDUARD_INGEST_SECRET=CHANGE_ME_LONG_RANDOM_INGEST_SECRET
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
POSTGRES_BACKUP_DIR=/app/backups
POSTGRES_BACKUP_RETENTION_DAYS=14
POSTGRES_BACKUP_MAX_AGE_HOURS=26
POSTGRES_BACKUP_INTERVAL_SECONDS=86400

# Product mode:
# disabled = no outbound email leaves the system.
# enabled = owner/customer mail send endpoints may send through connected Gmail/Outlook.
MAIL_SEND_MODE=disabled

# Pilot onboarding mode. Keep central_forwarding until OAuth verification is finished.
SAAS_MAIL_MODE=central_forwarding
GOOGLE_OAUTH_VERIFIED=false

MAIL_TO=michael@daltec.at
MAIL_SUBJECT=Daltec Eduard Angebot
GMAIL_SENDER_QUERY=office
GMAIL_SUBJECT_FILTER=Eduard
GMAIL_POLL_MINUTES=5

GOOGLE_OAUTH_CLIENT_PATH=/app/secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_PATH=/app/secrets/google-oauth-token.json

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
